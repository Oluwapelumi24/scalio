DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scalio
REDIS_URL=redis://localhost:6379
PORT=3000

# Email OTP verification (PRD §4.1 step 7) — sent via Resend
RESEND_API_KEY=
MAIL_FROM="Scalio <onboarding@resend.dev>"

# Payments (PRD §9.3) — Paystack handles `deposit`/`full_prepayment` bookings.
# The same secret key is used to sign/verify webhook payloads.
PAYSTACK_SECRET_KEY=

# Vendor admin auth — staff sign in with email+password (accounts are
# platform-provisioned, then activated via an emailed invite link).
VENDOR_JWT_SECRET=
VENDOR_WEB_URL="http://localhost:3001"
